# .env — prompt_to_viewport.sh 가 자동으로 읽습니다.
# 이 파일을 .env 로 복사한 뒤 본인 경로로 수정하세요.
#   cp .env.example .env

# Unreal 프로젝트 폴더 (안에 .uproject 파일이 있는 곳)
UE_PROJECT=/Users/jkjung/Unreal_Projects/MyProject

# (선택) Unity 프로젝트 폴더 (Assets/ 가 있는 곳)
# UNITY_PROJECT=/Users/jkjung/Unity_Projects/MyProject

# Ollama 모델 (기본: llama3.2)
# MODEL=llama3.2

# 백엔드 (기본: ollama)
# BACKEND=ollama

# (선택) 스펙 modules 배열 최대 개수(바닥 포함). Claude/Ollama 프롬프트에 반영; 모델이 넘기면 앞쪽만 유지.
# SETLAB_MAX_MODULES=10
# MAX_MODULES=10

# Hyper3D Rodin Gen-2 — 텍스트/멀티뷰→3D 메시 생성 (https://developer.hyper3d.ai)
# RODIN_API_KEY=
# HYPER3D_API_KEY=   # RODIN_API_KEY 대신 사용 가능 (문서상 이름)
# RODIN_CONCURRENCY=10
# RODIN_TIER=Gen-2
# RODIN_MESH_MODE=Raw
# RODIN_MATERIAL=PBR
# RODIN_QUALITY_OVERRIDE=150000
# RODIN_QUALITY_OVERRIDE_MAX=200000
# (공식 문서 poly 상한은 보통 20만; 50만 쓰려면 MAX=500000 + OVERRIDE≤MAX, 400 나오면 낮추기)
# RODIN_TIMEOUT=900

# 머티리얼 향상 — Hyper3D rodin_texture_only (RODIN_API_KEY와 동일 키 사용)
# 참조 이미지: images/<module_id>/front.* 가 없으면 image_gen으로 1장 생성
# IMAGE_GEN_BACKEND=flux (기본) → FLUX_API_KEY | google / google_image → GOOGLE_API_KEY
# IMAGE_GEN_BACKEND=flux
# GOOGLE_IMAGE_MODEL=gemini-3-pro-image-preview
# GOOGLE_IMAGE_ASPECT_RATIO=1:1
# MATERIAL_RODIN_CONCURRENCY=5
# RODIN_TEXTURE_RESOLUTION=High
# RODIN_TEXTURE_MAX_MODEL_MB=10
# RODIN_TEXTURE_TIMEOUT=900

# Hunyuan / STUDIO3D_API_KEY 는 제거됨. 메시·HD·머티리얼 향상은 전부 Rodin + RODIN_API_KEY.
# (레거시) Tripo3D
# TRIPO_API_KEY=
# TRIPO_CONCURRENCY=10
# TRIPO_HD_CONCURRENCY=10

# FLUX 1.1 Pro API 키 — IMAGE_GEN_BACKEND=flux 일 때 HD/머티리얼 참조 이미지 (https://docs.bfl.ai)
# FLUX_API_KEY=

# World Labs Marble API 키 — 전체 환경 생성 (https://worldlabs.ai)
# WORLDLABS_API_KEY=
# 모델: "Marble 0.1-plus" (최고 품질) 또는 "Marble 0.1-mini" (빠른 미리보기)
# WORLDLABS_MODEL=Marble 0.1-plus

# Google Gemini API 키 — IMAGE_GEN_BACKEND=google 일 때 참조 이미지 (generate_content + 이미지 출력)
# GOOGLE_API_KEY=

# (선택) Megascans 바닥 머티리얼 루트 경로 (Quixel Bridge로 다운로드한 위치)
# UE 콘텐츠 내 기본: /Game/Megascans/Surfaces
# MEGASCANS_ROOT=/Game/Megascans/Surfaces

# (선택) 머티리얼 향상 기본 스타일 프리셋
# generic_weathered / medieval_stone / aged_wood / rusty_metal / worn_brick
# MATERIAL_ENHANCE_STYLE=generic_weathered

# (로컬) Next는 :3000, FastAPI는 :8000 — basePath 없을 때 웹이 API를 찌를 주소 (기본값이 8000이지만 포트 바꿀 때만 설정)
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# (정적 배포 /setlab 등) Next basePath 쓸 때만. 비우면 로컬 dev는 API를 localhost:8000으로 호출
# NEXT_PUBLIC_BASE_PATH=/setlab

# (EC2 배포) FastAPI CORS — 브라우저 Origin은 path 없음. 예: http://54.1.2.3
# CORS_ORIGINS=http://YOUR_EC2_IP,http://localhost:3000,http://127.0.0.1:3000

# (선택) 웹 — Tripo GLB 정면 보정(도). 이 파일(루트 .env)에 넣어도 됨: next.config.ts 의 envDir=".." 로 읽음.
# NEXT_PUBLIC_HD_MESH_EXTRA_RX_DEG=0
# NEXT_PUBLIC_HD_MESH_EXTRA_RY_DEG=0
# NEXT_PUBLIC_HD_MESH_EXTRA_RZ_DEG=0

# (선택) 웹 — New Scene Generate 직후 자동 파이프라인
# unset / true / mesh+hd / all = Rodin 전 모듈(GLB) → 끝나면 HD(건물)
# hd / images+hd / hd-only = 일반 메시 생략, 곧바로 참조 이미지 → Rodin HD
# mesh = 메시 만 | false / off = 끔
# NEXT_PUBLIC_AUTO_PIPELINE_AFTER_GENERATE=mesh+hd

# (선택) 웹 — HD(또는 메시만)까지 끝난 뒤 자동으로 머티리얼 향상 → UE Deploy → (선택) Marble
# NEXT_PUBLIC_AUTO_STUDIO_COMPLETE=1     → 머티리얼 + Deploy (Marble 제외)
# NEXT_PUBLIC_AUTO_STUDIO_COMPLETE=full    → 머티리얼 + Deploy + Generate 직후 Marble(원경)
# NEXT_PUBLIC_AUTO_MATERIAL_AFTER_PIPELINE=1
# NEXT_PUBLIC_AUTO_DEPLOY_AFTER_PIPELINE=1
# NEXT_PUBLIC_AUTO_MARBLE_AFTER_GENERATE=1 → full 없이 Marble만 추가
# NEXT_PUBLIC_AUTO_MATERIAL_STYLE=generic_weathered

# (선택, 보안) API 토큰 인증 — 설정하면 모든 /api/* 호출에 Authorization: Bearer <토큰> 필요.
# 비우면 인증 끔(로컬 dev 기본). 뷰어 미디어용 /api/outputs·/api/web-refs 와 /health 는 항상 공개.
# 서버(SETLAB_API_TOKEN)와 웹(NEXT_PUBLIC_SETLAB_API_TOKEN)에 같은 값을 넣어야 함.
# SETLAB_API_TOKEN=
# NEXT_PUBLIC_SETLAB_API_TOKEN=

# (선택, 보안) /api/browse 탐색 허용 루트 (':' 로 구분). 설정 시 그 하위 디렉터리만 탐색 허용.
# 비우면 제한 없음(로컬 dev 기본).
# SETLAB_BROWSE_ROOTS=/Users/me/UnrealProjects:/Volumes/Work
