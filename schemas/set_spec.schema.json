{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/set_spec.schema.json",
  "title": "SetSpec",
  "type": "object",
  "required": ["title", "modules"],
  "properties": {
    "title": { "type": "string" },
    "era_style": { "type": "string" },
    "notes": { "type": "string" },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "asset", "position"],
        "properties": {
          "id": { "type": "string" },
          "asset": { "type": "string" },
          "position": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "rotation_deg": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "scale": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          }
        }
      }
    }
  }
}
